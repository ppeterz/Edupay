rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Schools ────────────────────────────────
    // Only the owner (uid === doc ID) can read/write their school doc.
    match /schools/{schoolId} {
      allow read, write: if request.auth != null
        && request.auth.uid == schoolId;
    }

    // ── Students ───────────────────────────────
    // Only the owning school can read its students. Write: false (Admin SDK only).
    match /students/{studentId} {
      allow read: if request.auth != null
        && resource.data.schoolId == request.auth.uid;
      allow write: if false;
    }

    // ── Invoices ───────────────────────────────
    // Only the owning school can read its invoices. Write: false (Admin SDK only).
    match /invoices/{invoiceId} {
      allow read: if request.auth != null
        && resource.data.schoolId == request.auth.uid;
      allow write: if false;
    }

    // ── Payments ───────────────────────────────
    // Only the owning school can read its payments. Write: false (Admin SDK only).
    match /payments/{paymentId} {
      allow read: if request.auth != null
        && resource.data.schoolId == request.auth.uid;
      allow write: if false;
    }

    // ── Reconciliation Events ──────────────────
    // Only the owning school can read its events. Write: false (Admin SDK only).
    match /reconciliation_events/{eventId} {
      allow read: if request.auth != null
        && resource.data.schoolId == request.auth.uid;
      allow write: if false;
    }

    // ── Webhook Log ────────────────────────────
    // Global read for authenticated users (written before school context exists).
    // Write: false (Admin SDK only).
    match /webhook_log/{logId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Webhook Errors ─────────────────────────
    // No client access. Write: false (Admin SDK only).
    match /webhook_errors/{errorId} {
      allow read, write: if false;
    }

    // ── Bulk Invoice Runs ──────────────────────
    // Only the owning school can read its bulk runs. Write: false (Admin SDK only).
    match /bulk_invoice_runs/{runId} {
      allow read: if request.auth != null
        && resource.data.schoolId == request.auth.uid;
      allow write: if false;
    }

    // ── Alerts ─────────────────────────────────
    // Global read for authenticated users (schoolId can be null).
    // Write: false (Admin SDK only).
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Withdrawals ─────────────────────────────
    // Only the owning school can read its withdrawals. Write: false (Admin SDK only).
    match /withdrawals/{withdrawalId} {
      allow read: if request.auth != null
        && resource.data.schoolId == request.auth.uid;
      allow write: if false;
    }
  }
}

